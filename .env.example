# Copy to .env and adjust. Used by docker-compose variable substitution and local dev.

# AI (optional — BYOK for Gemini)
GOOGLE_GEMINI_API_KEY=

# Optional third-party
MINIMAX_API_KEY=

# Frontend (production behind reverse proxy — often leave unset to use /api rewrites)
NEXT_PUBLIC_API_URL=

# Backend: comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Host folder of .json / .zolca libraries (Docker: matches volume mount)
LOCAL_DATABASE_DIR=
